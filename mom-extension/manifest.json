{
  "manifest_version": 3,
  "name": "MoM Meeting Recorder",
  "version": "1.0",
  "description": "Records Google Meet audio and uploads to FastAPI backend.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "tabs",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*"
    ]
  }
}